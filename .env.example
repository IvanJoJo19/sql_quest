# Подключение к полноценной версии LLM от OpenAI при её покупке
# Если LLM_API_KEY пуст, то используется режим ответов "по умолчанию".
LLM_API_URL=https://api.llm7.io/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Local app settings.
SQL_QUEST_PORT=8000
SQL_QUEST_DB=sql_quest
PGHOST=127.0.0.1
PGPORT=55432
